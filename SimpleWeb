@app.route('/')
def index():
    """Main page with all data"""
    # Get composite scores
    composites = get_composite_scores()
    if composites.empty:
        composites = pd.DataFrame({'model': ['No data'], 'composite_score': [0], 'sources_available': [0]})

    # Get feed entries
    conn = sqlite3.connect(DB_NAME)

    try:
        feed_approved = pd.read_sql_query("""
            SELECT * FROM feed_entries
            WHERE status = 'approved'
            ORDER BY created_at DESC
            LIMIT 50
        """, conn)

        feed_drafts = pd.read_sql_query("""
            SELECT * FROM feed_entries
            WHERE status = 'draft'
            ORDER BY created_at DESC
            LIMIT 50
        """, conn)

        feed_total = pd.read_sql_query("""
            SELECT COUNT(*) as count FROM feed_entries
        """, conn).iloc[0]['count']

    except Exception as e:
        print(f"⚠️ Error reading feed: {e}")
        feed_approved = pd.DataFrame()
        feed_drafts = pd.DataFrame()
        feed_total = 0

    # Get latest data for each source
    source_data = {}
    for source in SOURCES:
        name = source['name']
        try:
            df = pd.read_sql_query(f"""
                SELECT * FROM snapshots
                WHERE source = '{name}'
                ORDER BY snapshot_timestamp DESC
                LIMIT 100
            """, conn)

            if not df.empty:
                source_data[name] = df
            else:
                source_data[name] = pd.DataFrame()
        except Exception as e:
            print(f"⚠️ Error reading {name}: {e}")
            source_data[name] = pd.DataFrame()

    conn.close()

    return render_template_string(
        HTML_TEMPLATE,
        composites=composites.head(12).to_dict('records'),
        feed_approved=feed_approved.to_dict('records'),
        feed_drafts=feed_drafts.to_dict('records'),
        feed_total=feed_total,
        sources=SOURCES,
        source_data=source_data,
        now=datetime.now().strftime('%Y-%m-%d %H:%M'),
    )


@app.route('/api/composite')
def api_composite():
    """JSON endpoint for composite scores"""
    df = get_composite_scores()
    return jsonify(df.head(20).to_dict('records'))


@app.route('/api/source/<source_name>')
def api_source(source_name):
    """JSON endpoint for a specific source"""
    df = get_latest_normalized(source_name)
    return jsonify(df.head(20).to_dict('records'))


@app.route('/api/feed')
def api_feed():
    """JSON endpoint for feed entries"""
    conn = sqlite3.connect(DB_NAME)
    try:
        df = pd.read_sql_query("""
            SELECT * FROM feed_entries
            ORDER BY created_at DESC
            LIMIT 50
        """, conn)
        conn.close()
        return jsonify(df.to_dict('records'))
    except Exception as e:
        conn.close()
        return jsonify({'error': str(e)})


@app.route('/api/stats')
def api_stats():
    """JSON endpoint for system stats"""
    conn = sqlite3.connect(DB_NAME)
    try:
        # Count snapshots
        snapshots_count = pd.read_sql_query("SELECT COUNT(*) as count FROM snapshots", conn).iloc[0]['count']

        # Count models
        models_count = pd.read_sql_query("""
            SELECT COUNT(DISTINCT model) as count FROM snapshots
        """, conn).iloc[0]['count']

        # Count feed entries
        feed_count = pd.read_sql_query("SELECT COUNT(*) as count FROM feed_entries", conn).iloc[0]['count']

        # Last update
        last_update = pd.read_sql_query("""
            SELECT MAX(snapshot_timestamp) as last FROM snapshots
        """, conn).iloc[0]['last']

        conn.close()
        return jsonify({
            'snapshots': snapshots_count,
            'models': models_count,
            'feed_entries': feed_count,
            'last_update': last_update,
            'sources': len(SOURCES)
        })
    except Exception as e:
        conn.close()
        return jsonify({'error': str(e)})



"""
DATA FETCHER: Multiple Sources
Handles LMArena, MMLU-Pro, SWE-bench, and others
"""

import pandas as pd
import sqlite3
import requests
import numpy as np
from datetime import datetime
import json

DB_NAME = "benchmark.db"

# ============================================
# PARSER FUNCTIONS (One per source format)
# ============================================

def parse_lmaena_format(response):
    """Parser for LMArena API (wulong format)"""
    data = response.json()
    models = data.get("models", [])
    if models:
        df = pd.DataFrame(models)
        # Standardize column names
        if 'score' not in df.columns and 'elo' in df.columns:
            df = df.rename(columns={'elo': 'score'})
        return df
    return None

def parse_mmlu_format(response):
    """Parser for MMLU-Pro format"""
    data = response.json()
    # MMLU often returns: {"model_name": {"accuracy": 0.85, ...}}
    rows = []
    for model_name, scores in data.items():
        rows.append({
            'model': model_name,
            'score': scores.get('accuracy', 0) * 100,  # Convert to 0-100
            'vendor': scores.get('organization', 'Unknown')
        })
    return pd.DataFrame(rows) if rows else None

def parse_swebench_format(response):
    """Parser for SWE-bench format"""
    data = response.json()
    # SWE-bench often returns: {"data": [{"model": "gpt-4", "resolved": 0.62}]}
    items = data.get("data", [])
    rows = []
    for item in items:
        rows.append({
            'model': item.get('model', 'Unknown'),
            'score': item.get('resolved', 0) * 100,  # Convert to percentage
            'vendor': item.get('organization', 'Unknown')
        })
    return pd.DataFrame(rows) if rows else None

def parse_csv_format(response):
    """Parser for CSV files (Hugging Face, etc.)"""
    from io import StringIO
    df = pd.read_csv(StringIO(response.text))
    # Try to find the score column
    score_cols = ['score', 'accuracy', 'value', 'elo', 'rating']
    found_col = None
    for col in score_cols:
        if col in df.columns:
            found_col = col
            break
    if found_col:
        # If scores are 0-1, convert to 0-100
        if df[found_col].max() <= 1:
            df[found_col] = df[found_col] * 100
        return df
    return None


# ============================================
# NORMALIZATION FUNCTIONS
# ============================================

def normalize_minmax(df, score_col='score'):
    min_val = df[score_col].min()
    max_val = df[score_col].max()
    if max_val == min_val:
        return pd.Series([50] * len(df), index=df.index)
    return (df[score_col] - min_val) / (max_val - min_val) * 100

def normalize_percentile(df, score_col='score'):
    scores = df[score_col].values
    def get_percentile(x):
        lower_count = np.sum(scores < x)
        tie_count = np.sum(scores == x)
        return (lower_count + 0.5 * tie_count) / len(scores) * 100
    return df[score_col].apply(get_percentile)

def normalize_zscore(df, score_col='score'):
    scores = df[score_col].values
    mean = np.mean(scores)
    std = np.std(scores)
    if std == 0:
        return pd.Series([50] * len(df), index=df.index)
    z_scores = (scores - mean) / std
    return np.clip((z_scores + 3) / 6 * 100, 0, 100)

def apply_all_normalizations(df, score_col='score'):
    df['norm_minmax'] = normalize_minmax(df, score_col)
    df['norm_percentile'] = normalize_percentile(df, score_col)
    df['norm_zscore'] = normalize_zscore(df, score_col)
    df['norm_combined'] = (df['norm_minmax'] + df['norm_percentile'] + df['norm_zscore']) / 3
    return df

# ============================================
# FETCH FUNCTION
# ============================================

def fetch_source(source_config):
    """Fetch a source using its specific parser"""
    name = source_config["name"]
    url = source_config["url"]
    description = source_config.get("description", "")
    parser = source_config.get("parser", parse_lmaena_format)  # Default to LMArena parser
    
    print(f"\n📊 Processing: {name}")
    print(f"   Description: {description}")
    
    try:
        print(f"  📥 Fetching: {url}")
        response = requests.get(url, timeout=15)
        
        if response.status_code != 200:
            print(f"  ❌ Error {response.status_code}: {response.text[:100]}")
            return None
        
        # Use the specified parser
        df = parser(response)
        
        if df is None or df.empty:
            print(f"  ❌ Parser returned no data")
            return None
        
        # Ensure we have required columns
        if 'model' not in df.columns:
            print(f"  ❌ No 'model' column found")
            return None
        
        if 'score' not in df.columns:
            print(f"  ❌ No 'score' column found")
            print(f"  Available columns: {df.columns.tolist()}")
            return None
        
        print(f"  ✅ Fetched {len(df)} models")
        return df
        
    except Exception as e:
        print(f"  ❌ Error: {e}")
        return None

# ============================================
# MAIN PROCESSING
# ============================================

def main():
    print("=" * 60)
    print("📊 MULTI-SOURCE LEADERBOARD FETCHER")
    print("=" * 60)
    print(f"🕐 Started at: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    print(f"📋 Sources to fetch: {len(SOURCES)}")
    
    conn = sqlite3.connect(DB_NAME)
    successful = 0
    
    for source in SOURCES:
        name = source["name"]
        df = fetch_source(source)
        
        if df is not None and not df.empty:
            # Apply normalizations
            df = apply_all_normalizations(df, 'score')
            
            # Save to database
            df.to_sql(name, conn, if_exists='replace', index=False)
            print(f"  💾 Saved to table: {name}")
            print(f"  📊 Raw range: {df['score'].min():.1f} - {df['score'].max():.1f}")
            print(f"  📈 Normalized range: {df['norm_minmax'].min():.1f} - {df['norm_minmax'].max():.1f}")
            successful += 1
        else:
            print(f"  ⚠️ Skipping {name} - no data")
    
    conn.close()
    
    print("\n" + "=" * 60)
    print(f"✅ Complete! {successful}/{len(SOURCES)} sources fetched")
    print("=" * 60)

if __name__ == "__main__":
    main()
# Database file name
DB_NAME = "benchmark.db"

# Sources to fetch (add new ones here later)
SOURCES = [
    {
        "name": "lmaena_text",
        "url": "https://api.wulong.dev/arena-ai-leaderboards/v1/leaderboard?name=text",
        "description": "LMArena Text Leaderboard (Overall)"

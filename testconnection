import requests

url = "https://huggingface.co/datasets/lmsys/chatbot_arena_leaderboard/resolve/main/leaderboard_table_2025-03-26.csv"

try:
    response = requests.get(url)
    print(f"Status code: {response.status_code}")
    print(f"First 200 characters of the data: {response.text[:200]}")
except Exception as e:
    print(f"Error: {e}")
    